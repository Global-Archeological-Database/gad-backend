# =============================================================================
# GAD (Generative AI Dashboard) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit .env to version control — it is already in .gitignore.
# =============================================================================

# --- Required: Gemini API Key ------------------------------------------------
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Required: Google Maps API Key (for maps integration) ---------------------
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- Optional: Firebase / GCP Project ----------------------------------------
# Falls back to 'global-archaeological-database' if not set.
GCLOUD_PROJECT=your-gcp-project-id

# --- Optional: Cloud Storage Bucket ------------------------------------------
# Falls back to 'global-archaeological-database.firebasestorage.app' if not set.
STORAGE_BUCKET=your-storage-bucket-name

# --- Optional: Frontend URL (for CORS) ---------------------------------------
# Falls back to 'http://localhost:3000' via the ALLOWED_ORIGINS array.
FRONTEND_URL=http://localhost:3000

# --- Optional: Server Port ----------------------------------------------------
# Defaults to 8080 if not set.
PORT=8080

# --- Optional: Node Environment -----------------------------------------------
# Set to 'development' for verbose error messages in API responses.
NODE_ENV=development

# --- Optional: Service Account for Local Dev ----------------------------------
# If GEMINI_API_KEY is not set, the app will exit with an error.
# For Firebase Admin SDK authentication, the app uses application-default
# credentials. Set this to the path of your service account JSON file:
#   export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# A .gad-service-account.json file is already present in the repo root
# (also in .gitignore) for local development convenience.
# GOOGLE_APPLICATION_CREDENTIALS=.gad-service-account.json

# --- Required: Owner Email (for system-level operations) -----------------------
# Used as fallback for system-level operations.
OWNER_EMAIL=globalarcheologicaldatabase@gmail.com

# --- Optional: CORS Origins ---------------------------------------------------
# Comma-separated list of allowed CORS origins (default: http://localhost:3000,http://localhost:3001)
CORS_ORIGINS=

# --- Optional: Rate Limiting ---------------------------------------------------
# Rate limiting configuration (defaults shown)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_AI_MAX=20
RATE_LIMIT_UPLOAD_MAX=20

# --- Optional: Cache Durations (in seconds) ------------------------------------
# Cache durations in seconds (defaults shown)
CACHE_ARTIFACT_LIST_MS=60
CACHE_ARTIFACT_DETAIL_MS=300
CACHE_HEALTH_MS=30

# --- Optional: Maximum JSON Request Body Size ----------------------------------
# Maximum JSON request body size (default: 1mb)
MAX_JSON_SIZE=1mb

# --- Optional: Maximum Logo Upload Size ----------------------------------------
# Maximum logo upload size in bytes (default: 2MB = 2097152)
MAX_LOGO_SIZE=2097152

# --- Optional: Signed URL Expiry -----------------------------------------------
# Signed URL expiry in milliseconds (default: 15 minutes = 900000)
SIGNED_URL_EXPIRY_MS=900000
