rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isAdmin() { return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    match /artifacts/{id} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uploader_id == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uploader_id) || isAdmin();
    }
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if (isOwner(uid) && !('role' in request.resource.data.diff(resource.data).affectedKeys())) || isAdmin();
      allow delete: if isAdmin();
    }
    match /{document=**} { allow read, write: if false; }
  }
}
