# =============================================================================
# GAD (Generative AI Dashboard) — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# NEVER commit .env to version control — it is already in .gitignore.
# =============================================================================

# --- Required: Gemini API Key ------------------------------------------------
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Required: Google Maps API Key (for maps integration) ---------------------
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- Optional: Firebase / GCP Project ----------------------------------------
# Falls back to 'global-archaeological-database' if not set.
GCLOUD_PROJECT=your-gcp-project-id

# --- Optional: Cloud Storage Bucket ------------------------------------------
# Falls back to 'global-archaeological-database.firebasestorage.app' if not set.
STORAGE_BUCKET=your-storage-bucket-name

# --- Optional: Frontend URL (for CORS) ---------------------------------------
# Falls back to 'http://localhost:3000' via the ALLOWED_ORIGINS array.
FRONTEND_URL=http://localhost:3000

# --- Optional: Server Port ----------------------------------------------------
# Defaults to 8080 if not set.
PORT=8080

# --- Optional: Node Environment -----------------------------------------------
# Set to 'development' for verbose error messages in API responses.
NODE_ENV=development

# --- Optional: Service Account for Local Dev ----------------------------------
# If GEMINI_API_KEY is not set, the app will exit with an error.
# For Firebase Admin SDK authentication, the app uses application-default
# credentials. Set this to the path of your service account JSON file:
#   export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# A .gad-service-account.json file is already present in the repo root
# (also in .gitignore) for local development convenience.
# GOOGLE_APPLICATION_CREDENTIALS=.gad-service-account.json
